{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://u2re.space/schemas/cwsp/v2/packet.schema.json",
    "title": "CWSP v2 canonical packet",
    "type": "object",
    "required": [
        "op",
        "what",
        "uuid",
        "timestamp",
        "sender",
        "flags"
    ],
    "properties": {
        "op": {
            "enum": [
                "ask",
                "act",
                "result",
                "error"
            ]
        },
        "what": {
            "type": "string",
            "minLength": 1
        },
        "purpose": {
            "type": "string",
            "minLength": 1
        },
        "protocol": {
            "type": "string",
            "minLength": 1
        },
        "transport": {
            "type": "string",
            "minLength": 1
        },
        "uuid": {
            "type": "string",
            "minLength": 1
        },
        "timestamp": {
            "type": "integer",
            "minimum": 0
        },
        "sender": {
            "type": "string",
            "minLength": 1
        },
        "nodes": {
            "$ref": "#/$defs/destinations"
        },
        "destinations": {
            "$ref": "#/$defs/destinations"
        },
        "payload": {
            "$ref": "#/$defs/payload"
        },
        "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
        },
        "error": {
            "$ref": "#/$defs/error"
        },
        "extensions": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/extension"
            }
        },
        "flags": {
            "type": "object",
            "required": [
                "canonicalV2"
            ],
            "properties": {
                "canonicalV2": {
                    "const": true
                }
            },
            "additionalProperties": true
        }
    },
    "additionalProperties": true,
    "$defs": {
        "destinations": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "extension": {
            "type": "object",
            "required": [
                "id",
                "version"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[^/\\s]+\\.[^/\\s]+/.+$"
                },
                "version": {
                    "type": "integer",
                    "minimum": 1
                },
                "required": {
                    "type": "boolean",
                    "default": false
                },
                "data": true
            },
            "additionalProperties": false
        },
        "error": {
            "type": "object",
            "required": [
                "code",
                "message"
            ],
            "properties": {
                "code": {
                    "type": "string",
                    "minLength": 1
                },
                "message": {
                    "type": "string",
                    "minLength": 1
                },
                "details": true
            },
            "additionalProperties": true
        },
        "payload": {
            "anyOf": [
                {
                    "type": "object",
                    "properties": {
                        "asset": {
                            "$ref": "#/$defs/dataAsset"
                        },
                        "dataAsset": {
                            "$ref": "#/$defs/dataAsset"
                        },
                        "file": {
                            "$ref": "#/$defs/dataAsset"
                        },
                        "image": {
                            "$ref": "#/$defs/dataAsset"
                        }
                    },
                    "additionalProperties": true
                },
                {
                    "type": "array",
                    "items": true
                },
                {
                    "type": "string"
                },
                {
                    "type": "number"
                },
                {
                    "type": "boolean"
                },
                {
                    "type": "null"
                }
            ]
        },
        "dataAsset": {
            "type": "object",
            "required": [
                "hash",
                "name",
                "mimeType",
                "size",
                "source"
            ],
            "properties": {
                "hash": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "mimeType": {
                    "type": "string",
                    "minLength": 1
                },
                "size": {
                    "type": "integer",
                    "minimum": 0
                },
                "source": {
                    "type": "string",
                    "minLength": 1
                },
                "data": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        }
    }
}
