{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "types": [
            "node"
        ],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts"
    ]
}
