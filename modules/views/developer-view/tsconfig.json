{
    "include": [
        "./src/**/*.ts",
        "./demo/**/*.ts",
        "./test/*.ts",
        "./test/**/*.ts",
        "./*.js"
    ],
    "exclude": [
        "./dist/**/*",
        "./externals/**/*",
        "./legacy/**/*.ts",
        "./src/**/*.js",
        "./src/**/*.jsx"
    ],
    "compilerOptions": {
        "outDir": "./dist/",
        "paths": {
            "@phosphor-icons/core/assets/*": [
                "../../../node_modules/@phosphor-icons/core/assets/*"
            ],
            "views/types": [
                "../../shared/types.ts"
            ],
            "views/registry": [
                "../../shared/registry.ts"
            ],
            "views/apis/channel-actions": [
                "../../projects/subsystem/src/routing/api/channel-actions.ts"
            ],
            "com/config/Settings": [
                "../../shared/runtime/settings-config.ts"
            ],
            "fest/*": [
                "../../shared/fest/*"
            ],
            "fest/dom": [
                "../../projects/dom.ts/src/index.ts"
            ],
            "fest/lure": [
                "../../projects/lur.e/src/index.ts"
            ],
            "fest/object": [
                "../../projects/object.ts/src/index.ts"
            ],
            "fest/core": [
                "../../projects/core.ts/src/index.ts"
            ],
            "fest/icon": [
                "../../projects/icon.ts/src/index.ts"
            ],
            "fest/uniform": [
                "../../projects/uniform.ts/src/index.ts"
            ],
            "veela-lib": [
                "../../projects/veela.css/src/scss/index.scss"
            ],
            "veela-lib/*": [
                "../../projects/veela.css/src/scss/*"
            ],
            "boot/*": ["../shared/src/boot/*"],
            "views/*": ["../shared/views/*"],
            "shells/*": ["../shared/shells/*"],
            "core/*": ["../shared/src/*"],
            "com/*": ["../shared/src/*"],
            "shared/*": ["../shared/src/*"],
            "shared/transport/websocket": ["../../projects/subsystem/src/boot/websocket.ts"],
            "cwsp-shared/*": ["../../projects/cwsp-shared/src/*"],
            "fest/cwsp-shared": ["../../projects/cwsp-shared/src/index.ts"],
            "boot/native/cws-bridge": ["../../projects/subsystem/src/routing/native/cws-bridge.ts"],
            "boot/frontend-debug-capture": ["../../projects/subsystem/src/boot/frontend-debug-capture.ts"],
            "shared/native/clipboard-device": ["../../projects/subsystem/src/routing/native/clipboard-device.ts"],
        },
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM", "WebWorker"],
        "esModuleInterop": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "allowArbitraryExtensions": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": false,
        "declaration": false,
        "noEmit": true,
        "experimentalDecorators": true
    },
    "compileOnSave": false
}
