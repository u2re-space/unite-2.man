{
    "nativescript.tnsPath": "tools/ns-vscode.sh",
    "terminal.integrated.env.linux": {
        "ANDROID_HOME": "${env:HOME}/Android/Sdk",
        "PATH": "${env:HOME}/Android/Sdk/platform-tools:${env:HOME}/Android/Sdk/emulator:${env:PATH}"
    },
    "github.copilot.editor.enableAutoCompletions": false,
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false
    },
    "java.configuration.updateBuildConfiguration": "disabled",
    "java.project.sourcePaths": [
        "apps/CWSP/java",
        "apps/CWSAndroid/app/src/main/java"
    ],
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/.git/**": true,
        "**/.git/modules/**": true,
        "**/dist/**": true,
        "**/dist-crx/**": true,
        "**/build/**": true,
        "**/runtime/cwsp/**": true,
        "**/runtime/node_modules/**": true,
        "**/runtime/legacy/**": true,
        "**/runtime/dist/**": true,
        "**/coverage/**": true,
        "**/.gradle/**": true,
        "**/.android/**": true,
        "**/target/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/.git": true,
        "**/dist": true,
        "**/dist-crx": true,
        "**/build": true,
        "**/runtime/cwsp": true,
        "**/runtime/node_modules": true,
        "**/runtime/legacy": true,
        "**/coverage": true
    },
    "git.autoFetch": false,
    "git.fetchOnPull": false,
    "git.detectSubmodules": false,
    "git.detectSubmodulesLimit": 0,
    "extensions.autoCheckUpdates": false,
    "typescript.tsserver.maxTsServerMemory": 4096,
    "js/ts.experimental.useTsgo": false
}