{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CWSP Capacitor: WebView DevTools (attach :9222)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/apps/CrossWord",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "webpack:///./~/*": "${webRoot}/node_modules/*"
      }
    },
    {
      "name": "CWSAndroid (hybrid cwsp): Attach or Launch Debug (auto device)",
      "type": "android",
      "request": "attach",
      "appSrcRoot": "${workspaceFolder}/runtime/CWSAndroid/app/src/main",
      "apkFile": "${workspaceFolder}/runtime/CWSAndroid/app/build/outputs/apk/cwsp/debug/app-cwsp-debug.apk",
      "targetDevice": "${input:androidTargetSerial}",
      "preLaunchTask": "CWSAndroid (hybrid cwsp): Attach or launch debug (auto device)",
      "android": {
        "projectType": "apk"
      }
    },
    {
      "name": "CWSAndroid (hybrid cwsp): Attach or Launch Debug (192.168.0.196:5555)",
      "type": "android",
      "request": "attach",
      "appSrcRoot": "${workspaceFolder}/runtime/CWSAndroid/app/src/main",
      "apkFile": "${workspaceFolder}/runtime/CWSAndroid/app/build/outputs/apk/cwsp/debug/app-cwsp-debug.apk",
      "targetDevice": "192.168.0.196:5555",
      "preLaunchTask": "CWSAndroid (hybrid cwsp): Attach or launch debug (192.168.0.196:5555)",
      "android": {
        "projectType": "apk"
      }
    },
    {
      "name": "CWSAndroid (hybrid cwsp): Attach or Launch Debug (192.168.0.208:5555)",
      "type": "android",
      "request": "attach",
      "appSrcRoot": "${workspaceFolder}/runtime/CWSAndroid/app/src/main",
      "apkFile": "${workspaceFolder}/runtime/CWSAndroid/app/build/outputs/apk/cwsp/debug/app-cwsp-debug.apk",
      "targetDevice": "192.168.0.208:5555",
      "preLaunchTask": "CWSAndroid (hybrid cwsp): Attach or launch debug (192.168.0.208:5555)",
      "android": {
        "projectType": "apk"
      }
    },
    {
      "name": "CWSAndroid (hybrid cwsp): Attach or Launch Debug (forced target)",
      "type": "android",
      "request": "attach",
      "appSrcRoot": "${workspaceFolder}/runtime/CWSAndroid/app/src/main",
      "apkFile": "${workspaceFolder}/runtime/CWSAndroid/app/build/outputs/apk/cwsp/debug/app-cwsp-debug.apk",
      "targetDevice": "${input:androidTargetSerial}",
      "preLaunchTask": "CWSAndroid (hybrid cwsp): Attach or launch debug (forced target)",
      "android": {
        "projectType": "apk"
      }
    }
  ],
  "inputs": [
    {
      "id": "androidTargetSerial",
      "type": "command",
      "command": "extension.commandvariable.remember",
      "args": {
        "key": "androidTargetSerial",
        "default": "${promptStringRemember:androidTargetSerialPrompt}",
        "transform": {
          "promptStringRemember": {
            "androidTargetSerialPrompt": {
              "key": "androidTargetSerial",
              "description": "ADB serial/IP:port (CWSAndroid cwsp hybrid)",
              "default": "192.168.0.196:5555"
            }
          }
        }
      }
    }
  ]
}
