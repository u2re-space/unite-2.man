{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CWSP Capacitor: WebView DevTools (attach :9222)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/apps/CrossWord",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "webpack:///./~/*": "${webRoot}/node_modules/*"
      }
    },
    {
      "name": "NativeScript (CWSAndroid): Debug Android (192.168.0.196:5555)",
      "type": "nativescript",
      "request": "launch",
      "platform": "android",
      "appRoot": "${workspaceFolder}/apps/CWSAndroid",
      "sourceMaps": true,
      "watch": true,
      "emulator": false,
      "tnsArgs": "--device 192.168.0.196:5555",
      "preLaunchTask": "NS (CWSAndroid): adb connect 192.168.0.196:5555"
    },
    {
      "name": "NativeScript (CWSAndroid): Launch Android (any device)",
      "type": "nativescript",
      "request": "launch",
      "platform": "android",
      "appRoot": "${workspaceFolder}/apps/CWSAndroid",
      "sourceMaps": true,
      "watch": true
    },
    {
      "name": "NativeScript (CWSAndroid): Attach Android (192.168.0.196:5555)",
      "type": "nativescript",
      "request": "attach",
      "platform": "android",
      "appRoot": "${workspaceFolder}/apps/CWSAndroid",
      "sourceMaps": true,
      "tnsArgs": "--device 192.168.0.196:5555",
      "preLaunchTask": "NS (CWSAndroid): adb connect 192.168.0.196:5555"
    },
    {
      "name": "NativeScript (CWSAndroid): Debug Android (forced device)",
      "type": "nativescript",
      "request": "launch",
      "platform": "android",
      "appRoot": "${workspaceFolder}/apps/CWSAndroid",
      "sourceMaps": true,
      "watch": true,
      "emulator": false,
      "tnsArgs": "--device ${input:androidTargetSerial}",
      "preLaunchTask": "NS (CWSAndroid): adb connect (forced target)"
    },
    {
      "name": "NativeScript (CWSAndroid): Attach Android",
      "type": "nativescript",
      "request": "attach",
      "platform": "android",
      "appRoot": "${workspaceFolder}/apps/CWSAndroid",
      "sourceMaps": true
    },
    {
      "type": "pwa-msedge",
      "name": "Launch Microsoft Edge",
      "request": "launch",
      "runtimeArgs": [
        "--remote-debugging-port=9222"
      ],
      "url": "c:\\Users\\U2RE\\.vscode\\extensions\\ms-edgedevtools.vscode-edge-devtools-2.1.10\\out\\startpage\\index.html",
      "presentation": {
        "hidden": true
      }
    },
    {
      "type": "pwa-msedge",
      "name": "Launch Microsoft Edge in headless mode",
      "request": "launch",
      "runtimeArgs": [
        "--headless",
        "--remote-debugging-port=9222"
      ],
      "url": "c:\\Users\\U2RE\\.vscode\\extensions\\ms-edgedevtools.vscode-edge-devtools-2.1.10\\out\\startpage\\index.html",
      "presentation": {
        "hidden": true
      }
    },
    {
      "type": "vscode-edge-devtools.debug",
      "name": "Open Edge DevTools",
      "request": "attach",
      "url": "c:\\Users\\U2RE\\.vscode\\extensions\\ms-edgedevtools.vscode-edge-devtools-2.1.10\\out\\startpage\\index.html",
      "presentation": {
        "hidden": true
      }
    }
  ],
  "inputs": [
    {
      "id": "androidTargetSerial",
      "type": "command",
      "command": "extension.commandvariable.remember",
      "args": {
        "key": "androidTargetSerial",
        "default": "${promptStringRemember:androidTargetSerialPrompt}",
        "transform": {
          "promptStringRemember": {
            "androidTargetSerialPrompt": {
              "key": "androidTargetSerial",
              "description": "ADB serial/IP:port (NativeScript CWSAndroid)",
              "default": "192.168.0.196:5555"
            }
          }
        }
      }
    }
  ],
  "compounds": [
    {
      "name": "Launch Edge Headless and attach DevTools",
      "configurations": [
        "Launch Microsoft Edge in headless mode",
        "Open Edge DevTools"
      ]
    },
    {
      "name": "Launch Edge and attach DevTools",
      "configurations": [
        "Launch Microsoft Edge",
        "Open Edge DevTools"
      ]
    }
  ]
}
