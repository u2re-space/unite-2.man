{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CWSP Capacitor: adb forward WebView devtools (9222)",
      "type": "shell",
      "command": "${workspaceFolder}/runtime/cwsp/scripts/adb-forward-webview-debug.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Attach or launch debug (auto device)",
      "type": "shell",
      "command": "./gradlew",
      "args": [":app:attachDebug"],
      "windows": {
        "command": "gradlew.bat"
      },
      "options": {
        "cwd": "${workspaceFolder}/apps/CWSAndroid"
      },
      "group": "build",
      "detail": "installCwspDebug + launch space.u2re.cwsp (default -PcwsAdbFlavor=cwsp). Requires runtime/cwsp dist/capacitor for embedded WebView."
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Connect 192.168.0.196:5555",
      "type": "shell",
      "command": "adb",
      "args": ["connect", "192.168.0.196:5555"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Connect 192.168.0.208:5555",
      "type": "shell",
      "command": "adb",
      "args": ["connect", "192.168.0.208:5555"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Attach or launch debug (192.168.0.196:5555)",
      "type": "shell",
      "command": "./gradlew",
      "args": [":app:attachDebug", "-PadbSerial=192.168.0.196:5555"],
      "windows": {
        "command": "gradlew.bat"
      },
      "options": {
        "cwd": "${workspaceFolder}/apps/CWSAndroid"
      },
      "group": "build",
      "detail": "Build, install and launch cwsp hybrid on 192.168.0.196:5555."
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Attach or launch debug (192.168.0.208:5555)",
      "type": "shell",
      "command": "./gradlew",
      "args": [":app:attachDebug", "-PadbSerial=192.168.0.208:5555"],
      "windows": {
        "command": "gradlew.bat"
      },
      "options": {
        "cwd": "${workspaceFolder}/apps/CWSAndroid"
      },
      "group": "build",
      "detail": "Build, install and launch cwsp hybrid on 192.168.0.208:5555."
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Attach or launch debug (forced target)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "adb connect \"${input:androidTargetSerial}\" >/dev/null 2>&1 || true; ./gradlew :app:attachDebug -PadbSerial=\"${input:androidTargetSerial}\""
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-Command",
          "Set-Location -LiteralPath '${workspaceFolder}/apps/CWSAndroid'; adb connect \"${input:androidTargetSerial}\" | Out-Null; .\\gradlew.bat :app:attachDebug \"-PadbSerial=${input:androidTargetSerial}\""
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}/apps/CWSAndroid"
      },
      "group": "build",
      "detail": "Connects ADB if needed, then installs/launches cwsp hybrid (space.u2re.cwsp)."
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Logcat (192.168.0.196:5555)",
      "type": "shell",
      "command": "adb",
      "args": ["-s", "192.168.0.196:5555", "logcat"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Logcat (192.168.0.208:5555)",
      "type": "shell",
      "command": "adb",
      "args": ["-s", "192.168.0.208:5555", "logcat"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CWSAndroid (hybrid cwsp): Connected devices (ADB)",
      "type": "shell",
      "command": "adb",
      "args": ["devices", "-l"],
      "group": "build",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "androidTargetSerial",
      "type": "command",
      "command": "extension.commandvariable.remember",
      "args": {
        "key": "androidTargetSerial",
        "default": "${promptStringRemember:androidTargetSerialPrompt}",
        "transform": {
          "promptStringRemember": {
            "androidTargetSerialPrompt": {
              "key": "androidTargetSerial",
              "description": "ADB serial/IP:port (CWSAndroid cwsp hybrid)",
              "default": "192.168.0.196:5555"
            }
          }
        }
      }
    }
  ]
}
