{
    "include": [
        "**/*.mjs",
        "**/*.js",
        "**/*.ts",
        "**/*.d.ts",
        "**/*.tsx"
    ],
    "exclude": [
        "node_modules/**",
        "dist/**",
        "build/**",
        "coverage/**",
        "logs/**",
        "cache/**",
        "temp/**",
        "tmp/**",
        "temp/**",
        "tmp/**",
        "runtime/**"
    ],
    "compilerOptions": {
        "outDir": "./dist/",
        "skipLibCheck": true,
        "jsx": "preserve",
        "paths": {
            "/apps/*": [
                "./frontend/apps/*"
            ],
            "/externals/*": [
                "./frontend/externals/*"
            ],
            "/assets/*": [
                "./frontend/assets/*"
            ],
            "/frontend/*": [
                "./frontend/*"
            ],
            "fest/*": [
                "./modules/shared/fest/*"
            ],
            "fest/lure": [
                "./modules/projects/lur.e/src/index.ts"
            ],
            "fest/object": [
                "./modules/projects/object.ts/src/index.ts"
            ],
            "fest/dom": [
                "./modules/projects/dom.ts/src/index.ts"
            ],
            "fest/core": [
                "./modules/projects/core.ts/src/index.ts"
            ],
            "fest/icon": [
                "./modules/projects/icon.ts/src/index.ts"
            ],
            "fest/uniform": [
                "./modules/projects/uniform.ts/src/index.ts"
            ],
            "fest/fl-ui": [
                "./modules/projects/fl.ui/src/index.ts"
            ],
            "fest/ui": [
                "./modules/projects/fl.ui/src/index.ts"
            ],
            "@fl-ui/*": [
                "./modules/projects/fl.ui/src/ui/*"
            ],
            "@rs-com/*": [
                "./apps/CrossWord/src/com/*"
            ],
            "@rs-core/*": [
                "./apps/CrossWord/src/core/*"
            ],
            "@rs-frontend/*": [
                "./apps/CrossWord/src/frontend/*"
            ],
            "@rs-shared/*": [
                "./apps/CrossWord/shared/*"
            ]
        },
        "lib": [
            "ESNext",
            "DOM",
            "WebWorker",
            "ESNext.Promise"
        ],
        "types": [
            "chrome"
        ],
        "module": "ESNext",
        "target": "ESNext",
        "moduleDetection": "auto",
        "moduleResolution": "bundler",
        "pretty": true,
        "emitDeclarationOnly": true,
        "composite": true,
        "allowSyntheticDefaultImports": true,
        "allowArbitraryExtensions": true,
        "allowImportingTsExtensions": true,
        "esModuleInterop": true,
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "noEmit": true,
        "rewriteRelativeImportExtensions": true,
        "allowUnusedLabels": true,
        "allowUnreachableCode": true,
        "forceConsistentCasingInFileNames": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "isolatedModules": true,
        "emitDecoratorMetadata": false
    }
}